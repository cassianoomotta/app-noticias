###############################################################################
# .geminiignore
# Arquivo para reduzir contexto inútil/lixo ao Gemini/Antigravity.
# Sintaxe baseada em .gitignore:
# - comentários com #
# - glob patterns
# - / ancora na raiz
# - ! reabre arquivos/pastas antes ignorados
###############################################################################

############################
# VCS e metadados
############################
.git/
.gitmodules
.gitattributes
.git-blame-ignore-revs
.git_history/
.hg/
.svn/
CVS/

############################
# IDEs e editores
############################
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.iml
*.ipr
*.iws
*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*.swo
*~
.project
.classpath
.settings/
.cproject
.spyproject/
.ropeproject/

############################
# Sistema operacional
############################
.DS_Store
.AppleDouble
.LSOverride
Icon?
.Spotlight-V100/
.Trashes/
.fseventsd
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

############################
# Logs, dumps e rastros
############################
*.log
logs/
*.out
*.err
*.pid
*.pid.lock
*.seed
*.stackdump
*.trace
*.dmp
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
coverage-final.json
*.lcov

############################
# Variáveis de ambiente, segredos e credenciais
############################
.env
.env.*
*.env
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
*.kdbx
*.asc
*.gpg
*.ovpn
*.tfvars
*.tfvars.json
secrets.*
secret.*
credentials.*
*.credentials
*.npmrc
*.yarnrc
*.pypirc
.npmrc
.yarnrc
.yarnrc.yml
.python-version
.versions/

# Reabre apenas exemplos seguros
!.env.example
!.env.sample
!.env.template
!.env.schema
!.env.defaults
!.env.local.example

############################
# Dependências e gerenciadores JS/TS
############################
node_modules/
.node/
bower_components/
jspm_packages/
.pnp.*
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/
.parcel-cache/

