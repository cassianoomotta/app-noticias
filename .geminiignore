!openapi*.json
!swagger*.yaml
!swagger*.yml
!swagger*.json
!postman/**/*.json
!src/**/*.svg
!public/**/*.svg
!assets/**/*.svg

############################
# Pastas de framework/monorepo que costumam explodir contexto
############################
